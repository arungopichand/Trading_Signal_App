# Application
ASPNETCORE_ENVIRONMENT=Development
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend API keys
FINNHUB__APIKEY=replace_me
POLYGON__APIKEY=replace_me
NEWSAPI__APIKEY=replace_me
FMP__APIKEY=replace_me

# Data store
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace_me

# Deployment hooks (used by CI/CD)
RENDER_STAGING_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxx?key=xxxx
RENDER_PRODUCTION_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxxx?key=xxxx
RENDER_STAGING_HEALTHCHECK_URL=https://your-staging-backend.onrender.com/health
RENDER_PRODUCTION_HEALTHCHECK_URL=https://your-prod-backend.onrender.com/health

# Frontend runtime variables
VITE_API_BASE_URL=http://localhost:5013
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
